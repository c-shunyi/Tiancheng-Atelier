# 运行环境
NODE_ENV=development

# 服务端口
PORT=3000

# 数据库连接地址
DATABASE_URL="mysql://root:password@127.0.0.1:3306/tiancheng_atelier"

# JWT 密钥及过期时间
JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="7d"

# 跨域允许的来源（* 表示全部）
CORS_ORIGIN="*"

# 微信小程序配置
WX_APPID=""
WX_SECRET=""

# 文件存储配置
# 驱动：local（本地磁盘）/ cos（预留）
STORAGE_DRIVER=local
# 本地上传根目录（相对 server 工作目录或绝对路径）
UPLOAD_DIR=uploads
# 对外可访问基础 URL，用于拼接文件公开链接
PUBLIC_BASE_URL=http://localhost:3000
