generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "mysql"
}

enum AdminRole {
  admin
  super_admin
}

enum AdminStatus {
  active
  disabled
}

model ExampleItem {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(120)
  content   String?  @db.Text
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("example_items")
}

model AdminUser {
  id           Int         @id @default(autoincrement())
  username     String      @unique @db.VarChar(64)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  role         AdminRole   @default(admin)
  status       AdminStatus @default(active)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum UserStatus {
  active
  disabled
}

model User {
  id                Int        @id @default(autoincrement())
  username          String?    @unique @db.VarChar(64)
  phone             String?    @unique @db.VarChar(20)
  passwordHash      String?    @map("password_hash") @db.VarChar(255)
  openid            String?    @unique @db.VarChar(64)
  unionid           String?    @unique @db.VarChar(64)
  nickname          String     @default("") @db.VarChar(64)
  avatar            String     @default("") @db.VarChar(512)
  status            UserStatus @default(active)
  /// 今日已消耗的免费次数；每当跨过 freeQuotaResetAt 后重置为 0
  freeQuotaUsed     Int        @default(0) @map("free_quota_used")
  /// 下一次免费额度重置时间（通常为次日 00:00），请求时若已过则重置
  freeQuotaResetAt  DateTime   @default(now()) @map("free_quota_reset_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

enum CreationStatus {
  pending
  success
  failed
}

model PromptPreset {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(64)
  content   String   @db.Text
  cover     String   @default("") @db.VarChar(512)
  sortOrder Int      @default(0) @map("sort_order")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([enabled, sortOrder])
  @@map("prompt_presets")
}

model Creation {
  id             Int            @id @default(autoincrement())
  userId         Int            @map("user_id")
  prompt         String         @db.Text
  sourceImageKey String         @map("source_image_key") @db.VarChar(512)
  resultImageKey String         @default("") @map("result_image_key") @db.VarChar(512)
  model          String         @db.VarChar(64)
  size           String         @db.VarChar(16)
  status         CreationStatus @default(pending)
  errorMessage   String?        @map("error_message") @db.VarChar(512)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@map("creations")
}

model Address {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  name       String   @db.VarChar(32)
  phone      String   @db.VarChar(20)
  province   String   @db.VarChar(32)
  city       String   @db.VarChar(32)
  district   String   @db.VarChar(32)
  detail     String   @db.VarChar(255)
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, isDefault, createdAt])
  @@map("addresses")
}
