generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "mysql"
}

enum AdminRole {
  admin
  super_admin
}

enum AdminStatus {
  active
  disabled
}

model ExampleItem {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(120)
  content   String?  @db.Text
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("example_items")
}

model AdminUser {
  id           Int         @id @default(autoincrement())
  username     String      @unique @db.VarChar(64)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  role         AdminRole   @default(admin)
  status       AdminStatus @default(active)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum UserStatus {
  active
  disabled
}

model User {
  id           Int        @id @default(autoincrement())
  username     String?    @unique @db.VarChar(64)
  phone        String?    @unique @db.VarChar(20)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  openid       String?    @unique @db.VarChar(64)
  unionid      String?    @unique @db.VarChar(64)
  nickname     String     @default("") @db.VarChar(64)
  avatar       String     @default("") @db.VarChar(512)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

enum CreationStatus {
  pending
  success
  failed
}

model PromptPreset {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(64)
  content   String   @db.Text
  cover     String   @default("") @db.VarChar(512)
  sortOrder Int      @default(0) @map("sort_order")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([enabled, sortOrder])
  @@map("prompt_presets")
}

model Creation {
  id             Int            @id @default(autoincrement())
  userId         Int            @map("user_id")
  prompt         String         @db.Text
  sourceImageKey String         @map("source_image_key") @db.VarChar(512)
  resultImageKey String         @default("") @map("result_image_key") @db.VarChar(512)
  model          String         @db.VarChar(64)
  size           String         @db.VarChar(16)
  status         CreationStatus @default(pending)
  errorMessage   String?        @map("error_message") @db.VarChar(512)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@map("creations")
}
