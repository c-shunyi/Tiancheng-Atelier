/**
 * 用户信息结构。
 */
export type UserProfile = {
  id: number
  nickname: string
  avatar: string
  phone: string
}

/**
 * 全局用户状态结构。
 */
export type UserStoreState = {
  token: string
  userInfo: UserProfile | null
}

/**
 * 请求封装配置。
 */
export type ApiRequestOptions = {
  url: string
  method?: RequestMethod
  data?: any
  header?: UTSJSONObject | null
  loading?: boolean
  loadingTitle?: string
}
